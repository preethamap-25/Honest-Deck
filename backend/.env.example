# ── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRE_MINUTES=10080

# ── Groq API ────────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MAX_TOKENS=1024
GROQ_TEMPERATURE=0.1
GROQ_REQUEST_TIMEOUT=30
GROQ_MAX_RETRIES=2
GROQ_FALLBACK_MODELS=llama-3.1-8b-instant,llama-3.3-70b-versatile,llama3-8b-8192

# ── Agent ────────────────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=15
AGENT_TIMEOUT=180

# ── Web Scraping ─────────────────────────────────────────────────────────────
WEB_SEARCH_MAX_CHARS=3000
ARTICLE_MAX_CHARS=2000
HTTP_TIMEOUT=10
USER_AGENT=FactCheck-Bot/1.0

# ── Ollama (local LLM for text, URL, news, explanation) ─────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=your-mongodb-uri-here
MONGO_DB_NAME=seethru_db
MONGO_TIMEOUT_MS=5000

# ── News API ─────────────────────────────────────────────────────────────────
NEWS_API_KEY=your-news-api-key-here
NEWS_API_BASE_URL=https://newsapi.org/v2
NEWS_CACHE_TTL_SECONDS=300
GEO_CACHE_TTL_SECONDS=3600
GEO_LOOKUP_URL=http://ip-api.com/json
DEFAULT_COUNTRY=in

# ── Alert Thresholds ─────────────────────────────────────────────────────────
ALERT_FALSE_CONFIDENCE=0.8
ALERT_MISLEADING_CONFIDENCE=0.85
HUMAN_REVIEW_CONFIDENCE_THRESHOLD=0.65
DUPLICATE_SCORE_THRESHOLD=8.0

# ── App ──────────────────────────────────────────────────────────────────────
APP_VERSION=1.0.0
RATE_LIMIT_PER_MINUTE=60

# ── SMTP Email Alerts ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
ALERT_RECIPIENT=your-alert-email@gmail.com
